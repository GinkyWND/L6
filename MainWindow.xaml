<Window x:Class="Lesson5.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Параллельные вычисления" Height="360" Width="450">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Введите число N (размер диапазона):" Margin="0,5"/>
            <TextBox x:Name="txtN" Text="100000000" Margin="0,5" Height="25" VerticalContentAlignment="Center"/>

            <!-- Кнопка вычисления суммы -->
            <Button x:Name="btnSum" Content="Вычислить сумму (Параллельно)" Click="btnSum_Click" Margin="0,5" Height="30"/>
            
            <!-- НОВАЯ КНОПКА: Вычисление разности -->
            <Button x:Name="btnDiff" Content="Вычислить разность (Параллельно)" Click="btnDiff_Click" Margin="0,5" Height="30"/>

            <!-- Вывод суммы -->
            <TextBlock Text="Результат суммы:" Margin="0,15,0,0" FontWeight="Bold"/>
            <TextBlock x:Name="lblSumResult" Text="Ожидание..." Margin="0,2" FontSize="14" Foreground="DarkBlue"/>

            <!-- НОВЫЙ ВЫВОД: Результат разности -->
            <TextBlock Text="Результат разности (0 - 1 - 2 - ... - N):" Margin="0,10,0,0" FontWeight="Bold"/>
            <TextBlock x:Name="lblDiffResult" Text="Ожидание..." Margin="0,2" FontSize="14" Foreground="DarkRed"/>
            
            <ProgressBar x:Name="progressBar" IsIndeterminate="False" Height="15" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
